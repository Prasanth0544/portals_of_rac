# Canonical name: MONGODB_URI (MONGO_URI is deprecated but auto-migrated)
MONGODB_URI=mongodb://localhost:27017
#MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# ═══════════════════════════════════════════════════
# Database Names
# ═══════════════════════════════════════════════════
STATIONS_DB=StationsDB
PASSENGERS_DB=PassengersDB
TRAIN_DETAILS_DB=Trains_Details

# ═══════════════════════════════════════════════════
# Collection Names
# ═══════════════════════════════════════════════════
# (Train-specific collections like passengers/stations come from Trains_Details)
TRAIN_DETAILS_COLLECTION=Trains_Details
TTE_USERS_COLLECTION=tte_users
PASSENGER_ACCOUNTS_COLLECTION=passenger_accounts
REFRESH_TOKENS_COLLECTION=refresh_tokens
PUSH_SUBSCRIPTIONS_COLLECTION=push_subscriptions
IN_APP_NOTIFICATIONS_COLLECTION=in_app_notifications
UPGRADE_NOTIFICATIONS_COLLECTION=upgrade_notifications
STATION_REALLOCATIONS_COLLECTION=station_reallocations
OTP_STORE_COLLECTION=otp_store
UPGRADE_DENIAL_LOG_COLLECTION=upgrade_denial_log

# (Train-specific defaults now come from Trains_Details collection)

# ═══════════════════════════════════════════════════
# Server Config
# ═══════════════════════════════════════════════════
PORT=5000
NODE_ENV=production
LOG_LEVEL=INFO
# Canonical name: ALLOWED_ORIGINS (CORS_ORIGIN is deprecated but auto-migrated)
ALLOWED_ORIGINS=http://localhost:3000,https://portals-of-rac.vercel.app

# ═══════════════════════════════════════════════════
# Web Push (VAPID)
# ═══════════════════════════════════════════════════
# Generate keys: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
# Canonical name: VAPID_EMAIL (VAPID_SUBJECT is deprecated but auto-migrated)
VAPID_EMAIL=mailto:your-email@example.com

# ═══════════════════════════════════════════════════
# Auth (JWT)
# ═══════════════════════════════════════════════════
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# ═══════════════════════════════════════════════════
# Email — PRODUCTION (Render): Resend HTTP API
# ═══════════════════════════════════════════════════
# Render free tier BLOCKS outbound SMTP (ports 587/465).
# Use Resend instead — it sends via HTTPS (port 443) which Render never blocks.
#
# Setup (FREE — 3,000 emails/month):
#   1. Sign up at https://resend.com
#   2. Create an API key
#   3. (Optional) verify your domain for a custom "from" address
#   4. Add to Render environment variables:
#        RESEND_API_KEY=re_xxxxxxxxxxxx
#        RESEND_FROM_EMAIL=Indian Railways RAC <noreply@yourdomain.com>
#
# When RESEND_API_KEY is set, SMTP settings below are ignored.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Indian Railways RAC <onboarding@resend.dev>

# ═══════════════════════════════════════════════════
# Email — LOCAL DEV ONLY: Gmail SMTP
# ═══════════════════════════════════════════════════
# Used when RESEND_API_KEY is NOT set (local development).
# Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# ═══════════════════════════════════════════════════
# Frontend URLs (for email/push notification links)
# ═══════════════════════════════════════════════════
FRONTEND_URL=https://portals-of-rac.vercel.app
BACKEND_URL=https://portals-of-rac.onrender.com/


# ═══════════════════════════════════════════════════
# Redis (Optional — graceful fallback to in-memory)
# ═══════════════════════════════════════════════════
# Local:   redis://localhost:6379
# Docker:  redis://redis:6379
# Cloud:   redis://:password@host:port
# Upstash: rediss://default:token@endpoint:6379
#REDIS_URL=redis://localhost:6379

